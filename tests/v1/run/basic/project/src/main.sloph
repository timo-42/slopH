module demo::main;

import os::process::{Exit};
import std::io::{write};

fn describe(count: Int) -> Bytes
| 0 => bytes"none"
| 1 => bytes"one"
| n => bytes"many"

public fn main() -> Exit {
  let zero = write(describe(0));
  let separator_one = write(bytes" ");
  let one = write(describe(1));
  let separator_many = write(bytes" ");
  let many = write(describe(7));
  let newline = write(bytes"\n");
  Exit::Success()
}
