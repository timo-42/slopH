module memory_case::main;

import memory::{AllocationError, Block, allocate, capacity, drop};

fn invalid() -> Result[Int, AllocationError] {
  let block = allocate(64)?;
  defer drop(block);
  defer drop(block);
  Result::Ok[Int, AllocationError](capacity(block))
}

const main: Result[Int, AllocationError] { invalid() }
