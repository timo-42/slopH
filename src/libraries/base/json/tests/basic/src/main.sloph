module json_tests::main;

import json::{encode, parse};
import os::process::{Exit};
import std::io::{write};

public fn main() -> Exit {
  case parse(bytes"{\"message\":\"hi \\u263a\",\"items\":[1,-2,true,null]}") -> Exit {
    Result::Err(_parse_error) => { Exit::Failure(1) }
    Result::Ok(json_value) => {
      let rendered = write(encode(json_value));
      let newline = write(bytes"\n");
      case parse(bytes"{\"same\":1,\"same\":2}") -> Exit {
        Result::Ok(duplicate_value) => {
          let duplicate_rendered = write(encode(duplicate_value));
          let duplicate_newline = write(bytes"\n");
          Exit::Success()
        }
        Result::Err(_duplicate_error) => { Exit::Failure(2) }
      }
    }
  }
}
