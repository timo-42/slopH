module std_tests::int;

import os::process::{Exit};
import core::int::{to_bytes};
import std::io::{write};

fn print(item: Int) -> Unit {
  let item_written = write(to_bytes(item));
  write(bytes"\n")
}

public fn main() -> Exit {
  let zero = print(0);
  let positive = print(7);
  let negative = print(0 - 7);
  let positive_unbounded = print(123456789012345678901234567890);
  let negative_unbounded = print(0 - 123456789012345678901234567890);
  Exit::Success()
}
