module std_tests::bytes;

import os::process::{Exit};
import core::bytes::{length};
import core::int::{to_bytes};
import std::bytes::{is_empty};
import std::io::{write};

public fn main() -> Exit {
  let length_written = write(to_bytes(length(bytes"abc")));
  let first_newline = write(bytes"\n");
  let empty_written = write(if is_empty(bytes"") { bytes"true\n" } else { bytes"false\n" });
  let present_written = write(if is_empty(bytes"x") { bytes"true\n" } else { bytes"false\n" });
  Exit::Success()
}
