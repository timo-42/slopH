module core_bytes_tests::main;

import core::bytes::{RangeError, at, concat, equal, is_utf8, slice};
import core::int::{to_bytes};
import os::process::{Exit};
import std::io::{write};

fn print_bool(item: Bool) -> Unit {
  if item { write("true\n") } else { write("false\n") }
}

fn print_at(item: Option[Int]) -> Unit {
  case item -> Unit {
    Option::None() => { write("none\n") }
    Option::Some(byte) => {
      let byte_written = write(to_bytes(byte));
      write("\n")
    }
  }
}

fn print_slice(item: Result[Bytes, RangeError]) -> Unit {
  case item -> Unit {
    Result::Ok(bytes) => {
      let bytes_written = write(bytes);
      write("\n")
    }
    Result::Err(error) => { write("range\n") }
  }
}

public fn main() -> Exit {
  let equal_true = print_bool(equal("abc", "abc"));
  let equal_false = print_bool(equal("abc", "abd"));
  let byte_present = print_at(at("abc", 1));
  let byte_absent = print_at(at("abc", 3));
  let sliced = print_slice(slice("abcd", 1, 2));
  let invalid_slice = print_slice(slice("abcd", 3, 2));
  let joined = write(concat("ab", "cd"));
  let joined_newline = write("\n");
  let valid_utf8 = print_bool(is_utf8("hello \xe2\x82\xac"));
  let invalid_utf8 = print_bool(is_utf8("\xff"));
  Exit::Success()
}
