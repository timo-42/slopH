module sloph_tests::option;

import os::process::{Exit};
import core::int::{to_bytes};
import std::io::{write};
import sloph::option::{is_some, is_none, unwrap_or, map, and_then};

fn report_bool(label: Bytes, item: Bool) -> Unit {
  let label_written = write(label);
  if item { write("true\n") } else { write("false\n") }
}

fn report_int(label: Bytes, item: Int) -> Unit {
  let label_written = write(label);
  let item_written = write(to_bytes(item));
  write("\n")
}

fn halve(item: Int) -> Option[Int] {
  if item < 2 {
    if item < 1 { Option::Some[Int](0) } else { Option::None[Int]() }
  } else {
    Option::Some[Int](item - 2)
  }
}

public fn main() -> Exit {
  let some = Option::Some[Int](5);
  let none = Option::None[Int]();
  let is_some_present = report_bool("is_some present = ", is_some[Int](some));
  let is_some_absent = report_bool("is_some absent = ", is_some[Int](none));
  let is_none_present = report_bool("is_none present = ", is_none[Int](some));
  let is_none_absent = report_bool("is_none absent = ", is_none[Int](none));
  let unwrap_present = report_int("unwrap_or present = ", unwrap_or[Int](some, 9));
  let unwrap_absent = report_int("unwrap_or absent = ", unwrap_or[Int](none, 9));
  let doubled = map[Int, Int](some, fn(item: Int) -> Int { item * 2 });
  let map_present = report_int("map present = ", unwrap_or[Int](doubled, 9));
  let doubled_absent = map[Int, Int](none, fn(absent: Int) -> Int { absent * 2 });
  let map_absent = report_int("map absent = ", unwrap_or[Int](doubled_absent, 9));
  let chained = and_then[Int, Int](Option::Some[Int](7), halve);
  let chain_present = report_int("and_then present = ", unwrap_or[Int](chained, 9));
  let chained_absent = and_then[Int, Int](Option::Some[Int](1), halve);
  let chain_absent = report_int("and_then absent = ", unwrap_or[Int](chained_absent, 9));
  let chained_absent_input = and_then[Int, Int](none, halve);
  let chain_absent_input = report_int(
    "and_then absent input = ",
    unwrap_or[Int](chained_absent_input, 9)
  );
  Exit::Success()
}
