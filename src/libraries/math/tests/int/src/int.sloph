module math_tests::int;

import math::int::{absolute, minimum, maximum, sign, distance, is_negative, is_positive};
import os::process::{Exit};
import std::int::{to_bytes};
import std::io::{write};

fn report_int(label: Bytes, item: Int) -> Unit {
  let label_written = write(label);
  let item_written = write(to_bytes(item));
  write("\n")
}

fn report_bool(label: Bytes, item: Bool) -> Unit {
  let label_written = write(label);
  if item { write("true\n") } else { write("false\n") }
}

public fn main() -> Exit {
  let absolute_negative = report_int("absolute negative = ", absolute(0 - 7));
  let absolute_zero = report_int("absolute zero = ", absolute(0));
  let absolute_positive = report_int("absolute positive = ", absolute(7));
  let absolute_unbounded = report_int(
    "absolute unbounded = ",
    absolute(0 - 123456789012345678901234567890)
  );
  let minimum_ascending = report_int("minimum ascending = ", minimum(3, 9));
  let minimum_descending = report_int("minimum descending = ", minimum(9, 3));
  let minimum_equal = report_int("minimum equal = ", minimum(4, 4));
  let maximum_ascending = report_int("maximum ascending = ", maximum(3, 9));
  let maximum_descending = report_int("maximum descending = ", maximum(9, 3));
  let maximum_equal = report_int("maximum equal = ", maximum(4, 4));
  let sign_negative = report_int("sign negative = ", sign(0 - 7));
  let sign_zero = report_int("sign zero = ", sign(0));
  let sign_positive = report_int("sign positive = ", sign(7));
  let distance_ascending = report_int("distance ascending = ", distance(3, 9));
  let distance_descending = report_int("distance descending = ", distance(9, 3));
  let distance_equal = report_int("distance equal = ", distance(4, 4));
  let distance_unbounded = report_int(
    "distance unbounded = ",
    distance(0 - 123456789012345678901234567890, 123456789012345678901234567890)
  );
  let negative_negative = report_bool("is_negative negative = ", is_negative(0 - 1));
  let negative_zero = report_bool("is_negative zero = ", is_negative(0));
  let negative_positive = report_bool("is_negative positive = ", is_negative(1));
  let positive_negative = report_bool("is_positive negative = ", is_positive(0 - 1));
  let positive_zero = report_bool("is_positive zero = ", is_positive(0));
  let positive_positive = report_bool("is_positive positive = ", is_positive(1));
  Exit::Success()
}
