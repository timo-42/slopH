module collections_tests::set_test;

import collections::list::{List};
import collections::set::{Set, contains, insert, length, remove};
import core::bytes::{equal};
import core::int::{to_bytes};
import std::io::{write};

fn print_bool(item: Bool) -> Unit {
  if item { write("true\n") } else { write("false\n") }
}

public fn run_set() -> Unit {
  let empty = Set::Set[Bytes](List::Nil[Bytes]());
  let first = insert[Bytes](empty, "x", equal);
  let duplicate = insert[Bytes](first, "x", equal);
  let second = insert[Bytes](duplicate, "y", equal);
  let present = print_bool(contains[Bytes](second, "y", equal));
  let removed = remove[Bytes](second, "x", equal);
  let absent = print_bool(contains[Bytes](removed, "x", equal));
  let size_written = write(to_bytes(length[Bytes](removed)));
  write("\n")
}
