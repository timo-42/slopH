module collections_tests::list_test;

import collections::list::{List, filter, fold, get, length, map};
import core::int::{to_bytes};
import std::io::{write};

fn print_option(item: Option[Int]) -> Unit {
  case item -> Unit {
    Option::None() => { write("none\n") }
    Option::Some(number) => {
      let number_written = write(to_bytes(number));
      write("\n")
    }
  }
}

public fn run_list() -> Unit {
  let items = List::Cons[Int](1, List::Cons[Int](2, List::Cons[Int](3, List::Nil[Int]())));
  let list_length = write(to_bytes(length[Int](items)));
  let first_newline = write("\n");
  let present = print_option(get[Int](items, 1));
  let absent = print_option(get[Int](items, 9));
  let doubled = map[Int, Int](items, fn(item: Int) -> Int { item * 2 });
  let selected = filter[Int](doubled, fn(candidate: Int) -> Bool { 2 < candidate });
  let total = fold[Int, Int](selected, 0, fn(state: Int, member: Int) -> Int { state + member });
  let total_written = write(to_bytes(total));
  write("\n")
}
