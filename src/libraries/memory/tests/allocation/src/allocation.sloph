module memory_test::allocation;

import memory::{AllocationError, Allocator, allocate, capacity, drop, system};

fn allocated_capacity(allocator: borrow Allocator) -> Result[Int, AllocationError] {
  case allocate(allocator, 123) -> Result[Int, AllocationError] {
    Result::Ok(buffer) => {
      defer drop(buffer);
      Result::Ok[Int, AllocationError](capacity(buffer))
    }
    Result::Err(buffer_failure) => {
      Result::Err[Int, AllocationError](buffer_failure)
    }
  }
}

const main: Result[Int, AllocationError] {
  allocated_capacity(system())
}
