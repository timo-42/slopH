module memory_test::allocation;

import memory::{AllocationError, Block, allocate, capacity, drop};

const main: Result[Int, AllocationError] {
  case allocate(123) -> Result[Int, AllocationError] {
    Result::Ok(block) => {
      let stored: Int = capacity(block);
      let released: Unit = drop(block);
      Result::Ok[Int, AllocationError](stored)
    }
    Result::Err(failure) => {
      Result::Err[Int, AllocationError](failure)
    }
  }
}
