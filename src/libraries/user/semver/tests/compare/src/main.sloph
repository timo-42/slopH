module semver_test::main;

import semver::{compare, is_valid, Ordering, Version};
import os::process::{Exit};
import std::io::{write};

fn report(ordering: Ordering) -> Unit {
  case ordering -> Unit {
    Ordering::Less() => { write(bytes"less\n") }
    Ordering::Equal() => { write(bytes"equal\n") }
    Ordering::Greater() => { write(bytes"greater\n") }
  }
}

public fn main() -> Exit {
  let valid = is_valid(Version::Version(1, 2, 3));
  let first = report(compare(Version::Version(1, 2, 3), Version::Version(2, 0, 0)));
  let second = report(compare(Version::Version(1, 2, 3), Version::Version(1, 2, 3)));
  let third = if valid { report(compare(Version::Version(2, 0, 0), Version::Version(1, 9, 9))) }
  else { write(bytes"invalid\n") };
  Exit::Success()
}
