module syscall::posix::linux::amd64;

import syscall::posix::native::{NativeWriteError};

public fn native_write_once(
  descriptor: Int,
  bytes: Bytes,
  offset: Int,
  count: Int
) -> Result[Int, NativeWriteError] {
  primitive foreign.syscall.posix.linux.amd64.write(
    descriptor,
    bytes,
    offset,
    count
  )
}
