module syscall::posix::linux::amd64 when compiler::target::platform is (os::linux, arch::amd64);

import syscall::posix::native::{NativeWriteResult};

public fn native_write_once(
  descriptor: Int,
  bytes: Bytes,
  offset: Int,
  count: Int
) -> NativeWriteResult {
  primitive foreign.syscall.posix.linux.amd64.write(
    descriptor,
    bytes,
    offset,
    count
  )
}
