module syscall::posix::darwin::arm64 when compiler::target::platform is (os::darwin, arch::arm64);

import syscall::posix::native::{NativeWriteResult};

public fn native_write_once(
  descriptor: Int,
  bytes: Bytes,
  offset: Int,
  count: Int
) -> NativeWriteResult {
  primitive foreign.syscall.posix.darwin.arm64.write(
    descriptor,
    bytes,
    offset,
    count
  )
}
